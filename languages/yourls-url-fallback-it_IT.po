#: inc/admin-page.php
msgid "Are you sure you want to reset all settings?"
msgstr "Sei sicuro di voler reimpostare tutte le impostazioni?"

#: inc/admin-page.php
msgid "Settings reset to default."
msgstr "Impostazioni ripristinate ai valori predefiniti."

#: plugin.php
msgid "URL Fallback"
msgstr "URL alternativo"

#: inc/admin-page.php
msgid "detected &amp; active"
msgstr "rilevato e attivo"

#: inc/admin-page.php
msgid "The root page (<code>/</code>) is managed by <strong>AlternativeIndex</strong>. URL Fallback will only redirect visitors hitting <strong>unknown short URLs</strong> &mdash; root page interception is automatically disabled to avoid conflicts."
msgstr "La pagina radice (<code>/</code>) è gestita da <strong>AlternativeIndex</strong>. URL Fallback reindirizzerà solo i visitatori che accedono a <strong>URL brevi inesistenti</strong> &mdash; l'intercettazione della pagina radice è disabilitata automaticamente per evitare conflitti."

#: inc/admin-page.php
msgid "Fallback Settings"
msgstr "Impostazioni Fallback"

#: inc/admin-page.php
msgid "Fallback URL"
msgstr "URL di Fallback"

#: inc/admin-page.php
msgid "Visitors hitting a missing short URL will be redirected here."
msgstr "I visitatori che accedono a un URL breve inesistente verranno reindirizzati qui."

#: inc/admin-page.php
msgid "Visitors hitting a missing short URL or the YOURLS root page will be redirected here."
msgstr "I visitatori che accedono a un URL breve inesistente o alla pagina radice di YOURLS verranno reindirizzati qui."

#: inc/admin-page.php
msgid "Redirect Type"
msgstr "Tipo di Reindirizzamento"

#: inc/admin-page.php
msgid "Use 302 while testing, switch to 301 once the destination is stable (301 is cached by browsers)."
msgstr "Usa 302 durante i test, passa a 301 una volta che la destinazione è stabile (il 301 viene memorizzato nella cache dai browser)."

#: inc/admin-page.php
msgid "302 &ndash; Temporary Redirect"
msgstr "302 &ndash; Reindirizzamento Temporaneo"

#: inc/admin-page.php
msgid "301 &ndash; Permanent Redirect"
msgstr "301 &ndash; Reindirizzamento Permanente"

#: inc/admin-page.php
msgid "Notes"
msgstr "Note"

#: inc/admin-page.php
msgid "When <strong>no fallback URL is set</strong>, YOURLS behaves as normal (default 404 page)."
msgstr "Quando <strong>non è impostato alcun URL di fallback</strong>, YOURLS si comporta normalmente (pagina 404 predefinita)."

#: inc/admin-page.php
msgid "The redirect fires for <strong>any unknown keyword</strong>."
msgstr "Il reindirizzamento si attiva per <strong>qualsiasi parola chiave sconosciuta</strong>."

#: inc/admin-page.php
msgid "The redirect fires for <strong>any unknown keyword</strong> and when visiting the <strong>YOURLS root URL</strong> directly."
msgstr "Il reindirizzamento si attiva per <strong>qualsiasi parola chiave sconosciuta</strong> e quando si visita direttamente l'<strong>URL radice di YOURLS</strong>."

#: inc/admin-page.php
msgid "Valid short URLs continue to work without any change."
msgstr "Gli URL brevi validi continuano a funzionare senza alcuna modifica."

#: inc/admin-page.php
msgid "Short URLs ending with <strong>+</strong> (YOURLS stats pages) are passed through only if the keyword exists; otherwise the fallback redirect applies."
msgstr "Gli URL brevi che terminano con <strong>+</strong> (pagine statistiche di YOURLS) vengono inoltrati solo se la parola chiave esiste; in caso contrario si applica il reindirizzamento di fallback."

#: inc/admin-page.php
msgid "<strong>AlternativeIndex</strong> is active: the root page is handled by that plugin and URL Fallback will not intercept it."
msgstr "<strong>AlternativeIndex</strong> è attivo: la pagina radice è gestita da quel plugin e URL Fallback non la intercetterà."

#: inc/admin-page.php
msgid "Save Settings"
msgstr "Salva Impostazioni"

#: inc/admin-page.php
msgid "Reset to Default"
msgstr "Ripristina impostazioni predefinite"

#: inc/admin-page.php
msgid "Back to top"
msgstr "Torna all'inizio"

#: inc/admin-page.php
msgid "Please enter a valid URL (e.g. https://example.com or www.example.com)."
msgstr "Inserisci un URL valido (ad esempio https://example.com o www.example.com)."

#: inc/admin-page.php
msgid "Settings saved successfully!"
msgstr "Impostazioni salvate con successo!"

#: inc/update-check.php
msgid "New version available: <strong>%s</strong>!"
msgstr "Nuova versione disponibile: <strong>%s</strong>!"

#: inc/update-check.php
msgid "View details on GitHub"
msgstr "Visualizza dettagli su GitHub"

#: inc/update-check.php
msgid "Update Available"
msgstr "Aggiornamento Disponibile"
